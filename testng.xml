<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemo Automation Suite" verbose="1">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="org.automation.tests.LoginTest" />
        </classes>
    </test>
    <test name="Home Tests">
        <classes>
            <class name="org.automation.tests.HomeTest" />
        </classes>
    </test>
    <test name="Page Tests">
        <classes>
            <class name="org.automation.tests.ProductTest" />
        </classes>
    </test>

</suite>